@{
    ViewData["Title"] = "Dashboard";
}

<div class="container mt-5">

    <h1 class="text-center mb-5">
        Admin Dashboard
    </h1>

    <div class="row">

        <div class="col-md-3">

            <div class="card shadow-lg border-0 text-center">

                <div class="card-body">

                    <h5>Total Events</h5>

                    <h1 class="text-primary">
                        @ViewBag.TotalEvents
                    </h1>

                </div>

            </div>

        </div>

        <div class="col-md-3">

            <div class="card shadow-lg border-0 text-center">

                <div class="card-body">

                    <h5>Total Bookings</h5>

                    <h1 class="text-success">
                        @ViewBag.TotalBookings
                    </h1>

                </div>

            </div>

        </div>

        <div class="col-md-3">

            <div class="card shadow-lg border-0 text-center">

                <div class="card-body">

                    <h5>Total Revenue</h5>

                    <h1 class="text-danger">
                        @ViewBag.TotalRevenue TK
                    </h1>

                </div>

            </div>

        </div>

        <div class="col-md-3">

            <div class="card shadow-lg border-0 text-center">

                <div class="card-body">

                    <h5>Sold Out Events</h5>

                    <h1 class="text-dark">
                        @ViewBag.SoldOutEvents
                    </h1>

                </div>

            </div>

        </div>

    </div>

    <br />
    <br />

    <div class="card shadow-lg border-0">

        <div class="card-header bg-dark text-white">
            Quick Navigation
        </div>

        <div class="card-body">

            <a asp-controller="Event"
               asp-action="Index"
               class="btn btn-primary m-2">

                Manage Events

            </a>

            <a asp-controller="Booking"
               asp-action="Index"
               class="btn btn-success m-2">

                Manage Bookings

            </a>

            <a asp-controller="Account"
               asp-action="Logout"
               class="btn btn-danger m-2">

                Logout

            </a>

        </div>

    </div>

</div>