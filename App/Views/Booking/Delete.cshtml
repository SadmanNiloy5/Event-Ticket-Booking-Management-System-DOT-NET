@model BLL.DTOs.BookingDTO

@{
    ViewData["Title"] = "Delete Booking";
}

<div class="container mt-5">

    <div class="row justify-content-center">

        <div class="col-md-5">

            <div class="card shadow-lg border-0 rounded-4">

                <div class="card-header bg-danger text-white text-center rounded-top-4">
                    <h2>Delete Booking</h2>
                </div>

                <div class="card-body text-center p-4">

                    <h4>Are You Sure?</h4>

                    <hr />

                    <p>
                        <strong>Booking Id:</strong> @Model.Id
                    </p>

                    <p>
                        <strong>User Id:</strong> @Model.UserId
                    </p>

                    <p>
                        <strong>Event Id:</strong> @Model.EventId
                    </p>

                    <p>
                        <strong>Total Amount:</strong> @Model.TotalAmount TK
                    </p>

                    <form method="post">

                        <input type="submit"
                               name="Decision"
                               value="Yes"
                               class="btn btn-danger" />

                        <input type="submit"
                               name="Decision"
                               value="No"
                               class="btn btn-secondary" />

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>